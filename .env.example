# Remy — Environment Variables
# Copy this file to .env and set your values
# Or run: remy --setup

# ============== REQUIRED ==============

# Google Gemini API Key
# Get it at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============== MODELS ==============

# Gemini model for live audio (voice channel)
# Default: gemini-2.5-flash-native-audio-preview-12-2025
# GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Gemini voice name
# Options: Zephyr, Puck, Charon, Kore, Fenrir, Aoede
# Default: Zephyr
# GEMINI_VOICE=Zephyr

# Gemini model for text channels (Telegram, Web/Desktop, Autonomous)
# Default: gemini-3-flash-preview
# SUMMARY_MODEL=gemini-3-flash-preview

# ============== TELEGRAM ==============

# Telegram Bot Token (from @BotFather)
# Required only for --telegram mode
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram chat ID for proactive notifications
# Required for background brain notifications and proactive sessions
# PROACTIVE_CHAT_ID=123456789

# Minimum Telegram severity for operator alerts emitted by the runtime watch loop
# info = all operator updates, warning = only degraded states and above, critical = only hard failures
# Default: warning
# TELEGRAM_OPERATOR_ALERT_MIN_LEVEL=warning

# ============== WEB / DESKTOP ==============

# Web server host and port (for --web and --desktop modes)
# Default: 127.0.0.1:8080
# WEB_HOST=127.0.0.1
# WEB_PORT=8080

# ============== PROACTIVE ==============

# Interval for proactive brain insights (seconds)
# Default: 300 (5 minutes)
# PROACTIVE_INTERVAL_SEC=300

# ============== AUTONOMOUS MODE ==============

# Enable autonomous mode (also requires --autonomous CLI flag)
# AUTONOMY_ENABLED=False

# Use the v3 mission runtime by default. Set false only to run the legacy v2 loop.
# AUTONOMY_V3=True

# Seconds between autonomous cycles
# Default: 120 (2 minutes)
# AUTONOMY_CYCLE_INTERVAL_SEC=120

# Token budget limits
# AUTONOMY_DAILY_TOKEN_LIMIT=100000
# AUTONOMY_HOURLY_TOKEN_LIMIT=20000
# AUTONOMY_SESSION_TOKEN_LIMIT=500000

# Max actions per hour (rate limiting)
# AUTONOMY_MAX_ACTIONS_PER_HOUR=20

# Auto-stop session after N minutes
# AUTONOMY_MAX_SESSION_MINUTES=30

# Quiet hours — skip cycles during this period
# Default: 23:00 - 07:00
# AUTONOMY_QUIET_HOURS_START=23
# AUTONOMY_QUIET_HOURS_END=7

# Auto-approve sandbox tools that pass tests (no human review)
# AUTONOMY_AUTO_APPROVE_SANDBOX=False

# Send Telegram notifications about autonomous actions
# AUTONOMY_TELEGRAM_NOTIFICATIONS=True

# Extra filesystem paths the autonomous agent can read (comma-separated)
# By default, only data/ directory is accessible
# AUTONOMY_ALLOWED_READ_PATHS=

# ============== PROACTIVE SESSIONS ==============

# Let autonomous agent initiate Telegram conversations
# AUTONOMY_PROACTIVE_SESSIONS_ENABLED=True

# Max proactive sessions per day
# AUTONOMY_PROACTIVE_MAX_PER_DAY=3

# Min interval between proactive sessions (seconds)
# Default: 7200 (2 hours)
# AUTONOMY_PROACTIVE_MIN_INTERVAL_SEC=7200
